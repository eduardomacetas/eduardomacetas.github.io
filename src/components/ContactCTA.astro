---
import Icon from "./Icon.astro";
---

<aside class="contact-cta">
	<div class="cta-content">
		<div class="cta-text">
			<h2>Let's work together</h2>
			<p>
				7+ years finding bugs before users do. Open to new QA
				opportunities — let's talk.
			</p>
		</div>
		<div class="cta-actions">
			<a href="mailto:eduardo.macetas@gmail.com" class="btn-primary">
				<Icon icon="paper-plane-tilt" size="1em" />
				Send a message
			</a>
			<a
				href="https://www.linkedin.com/in/jorge-macetas"
				class="btn-secondary"
				target="_blank"
				rel="noopener"
			>
				<Icon icon="linkedin-logo" size="1em" />
				Connect on LinkedIn
			</a>
		</div>
	</div>
</aside>

<style>
	.contact-cta {
		padding: 3.5rem 0;
	}

	.cta-content {
		background: var(--canvas-subtle);
		border: 1px solid var(--border-default);
		border-radius: var(--radius-lg);
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.cta-text h2 {
		font-size: var(--text-2xl);
		font-weight: 700;
		color: var(--fg-default);
		margin-bottom: 0.5rem;
		letter-spacing: -0.02em;
	}

	.cta-text p {
		color: var(--fg-muted);
		font-size: var(--text-md);
		line-height: 1.6;
		max-width: 48ch;
	}

	.cta-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 1.25rem;
		border-radius: var(--radius-sm);
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		transition: all var(--theme-transition);
	}

	.btn-primary {
		/* background: var(--accent-default); */
		background: var(--cyan);
		/* color: var(--fg-on-accent); */
		color: var(--cyan-fg);
		/* border: 1px solid var(--accent-default); */
		border: 1px solid var(--cyan);
	}

	.btn-primary:hover {
		/* background: var(--fg-muted); */
		background: var(--cyan-hover);
		border-color: var(--cyan-hover);
	}

	.btn-secondary {
		background: transparent;
		color: var(--fg-muted);
		border: 1px solid var(--border-default);
	}

	.btn-secondary:hover {
		border-color: var(--fg-su);
		color: var(--fg-default);
		background: var(--canvas-subtle);
	}

	@media (min-width: 50em) {
		.cta-content {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			padding: 2.5rem 3rem;
		}

		.cta-actions {
			flex-shrink: 0;
		}
	}
</style>
