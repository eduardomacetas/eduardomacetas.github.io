---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Eduardo Macetas — QA Engineer',
	description = 'QA Automation Engineer with 8+ years of hands-on experience in both manual and automated testing for web and mobile applications. Self-driven and self-taught, I design scalable automation frameworks, integrate them into CI/CD pipelines, and know when manual testing adds more value than automation. I ensure quality from the first commit to production. — based in Arequipa, Perú.',
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<meta name="description" property="og:description" content={description} />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
	rel="stylesheet"
/>
<script is:inline>
	document.documentElement.classList.add('theme-dark');
</script>
