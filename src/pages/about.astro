<style>
	.about {
		padding-top: 3.5rem;
		padding-bottom: 2rem;
	}

	.about-header {
		max-width: 52ch;
		margin-bottom: 3rem;
	}

	.about-header h1 {
		font-size: clamp(2rem, 5vw, var(--text-5xl));
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-bottom: 0.75rem;
	}

	.subtitle {
		font-size: var(--text-lg);
		color: var(--gray-400);
		line-height: 1.6;
	}

	.about-grid {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.section h2 {
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--gray-0);
		letter-spacing: -0.02em;
		margin-bottom: 1.25rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.prose {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.prose p {
		font-size: var(--text-md);
		color: var(--gray-300);
		line-height: 1.7;
		max-width: 64ch;
	}

	.prose strong {
		color: var(--gray-100);
		font-weight: 600;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem 2rem;
	}

	.skill-group h4 {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--gray-400);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.625rem;
	}

	.skill-group ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.skill-group li {
		font-size: var(--text-sm);
		color: var(--gray-300);
		font-family: var(--font-mono);
	}

	@media (min-width: 50em) {
		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
