---
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QA Engineer con más de 7 años de experiencia en pruebas manuales y automatizadas." />
    <title>Jorge Macetas — QA Engineer</title>
    <style>
      @import "tailwindcss";

      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

      body {
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>

  <body class="bg-white text-gray-900 antialiased">

    <!-- NAVBAR -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-semibold text-sm tracking-tight">JM</a>
        <nav class="flex items-center gap-6 text-sm text-gray-500">
          <a href="mailto:eduardo.macetas@gmail.com" class="hover:text-gray-900 transition">Contacto</a>
          <a href="https://www.linkedin.com/in/jorge-macetas" target="_blank" class="hover:text-gray-900 transition">LinkedIn</a>
          <a href="https://github.com/eduardomacetas" target="_blank" class="hover:text-gray-900 transition">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 pt-32">

      <!-- HERO -->
      <section class="pb-24">
        <p class="text-sm text-gray-400 mb-3 uppercase tracking-widest">QA Engineer</p>
        <h1 class="text-6xl font-bold tracking-tight mb-6 leading-tight">Jorge Macetas</h1>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mb-10">
          QA Engineer con más de 7 años de experiencia en pruebas manuales y automatizadas
          para aplicaciones web y móviles. Diseño frameworks de automatización escalables,
          los integro en pipelines CI/CD y me aseguro de que la calidad esté presente
          desde el primer commit hasta producción.
        </p>
        <div class="flex gap-3">
          <a href="mailto:eduardo.macetas@gmail.com"
            class="bg-gray-900 text-white text-sm px-5 py-2.5 rounded-lg hover:bg-gray-700 transition font-medium">
            Contacto
          </a>
          <a href="https://www.linkedin.com/in/jorge-macetas" target="_blank"
            class="border border-gray-200 text-sm px-5 py-2.5 rounded-lg hover:bg-gray-50 transition font-medium text-gray-700">
            LinkedIn
          </a>
          <a href="https://github.com/eduardomacetas" target="_blank"
            class="border border-gray-200 text-sm px-5 py-2.5 rounded-lg hover:bg-gray-50 transition font-medium text-gray-700">
            GitHub
          </a>
        </div>
      </section>

      <!-- SKILLS -->
      <section class="py-16 border-t border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-10">Skills & Tecnologías</h2>

        <div class="flex flex-col gap-8">

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-0.5">Testing</span>
            <div class="flex flex-wrap gap-2">
              {["Playwright", "Cypress", "Selenium", "WebdriverIO", "Appium", "Cucumber", "Postman", "BDD"].map(skill => (
                <span class="border border-gray-200 text-gray-600 px-3 py-1 rounded-full text-xs font-medium">{skill}</span>
              ))}
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-0.5">Desarrollo</span>
            <div class="flex flex-wrap gap-2">
              {["JavaScript", "TypeScript", "Node.js", "React", "React Native"].map(skill => (
                <span class="border border-gray-200 text-gray-600 px-3 py-1 rounded-full text-xs font-medium">{skill}</span>
              ))}
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-0.5">Herramientas</span>
            <div class="flex flex-wrap gap-2">
              {["Jira", "Asana", "Git", "GitHub", "CI/CD", "GitHub Actions"].map(skill => (
                <span class="border border-gray-200 text-gray-600 px-3 py-1 rounded-full text-xs font-medium">{skill}</span>
              ))}
            </div>
          </div>

        </div>
      </section>

      <!-- EXPERIENCIA -->
      <section class="py-16 border-t border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-10">Experiencia</h2>

        <div class="flex flex-col gap-12">

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">Ago 2025<br/>Jun 2026</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">QA Automation Engineer</h3>
              <p class="text-sm text-gray-400 mb-3">Subscribe</p>
              <ul class="text-sm text-gray-500 space-y-1.5">
                <li>Testing funcional, regresión, integración, exploratorio, end-to-end y de APIs para aplicaciones web.</li>
                <li>Diseño y mantenimiento de suites automatizadas con Playwright y Cypress.</li>
                <li>Validación de REST APIs con Postman para garantizar integridad de datos.</li>
                <li>Creación de planes y casos de prueba basados en requerimientos de negocio.</li>
                <li>Colaboración con developers, PMs y diseñadores usando Jira y Asana.</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">Ene 2023<br/>Jul 2025</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">QA Automation Engineer</h3>
              <p class="text-sm text-gray-400 mb-3">The Church of Jesus Christ of Latter-day Saints</p>
              <ul class="text-sm text-gray-500 space-y-1.5">
                <li>Diseño y mantenimiento de frameworks con Selenium, WebdriverIO, Appium y Cucumber.</li>
                <li>Testing manual y automatizado para apps web y mobile en entornos Agile.</li>
                <li>Aplicación de metodologías BDD para mejorar colaboración entre equipos técnicos y de negocio.</li>
                <li>Documentación de calidad: planes, casos de prueba y evidencias a lo largo del SDLC.</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">Jun 2019<br/>Ene 2023</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">QA Automation Engineer</h3>
              <p class="text-sm text-gray-400 mb-3">GuideCX</p>
              <ul class="text-sm text-gray-500 space-y-1.5">
                <li>Testing funcional, regresión, exploratorio y end-to-end en múltiples releases de un SaaS.</li>
                <li>Desarrollo y mantenimiento de suites automatizadas con Cypress y Playwright.</li>
                <li>Integración de pruebas automatizadas en pipelines CI/CD para ciclos de entrega más rápidos.</li>
                <li>Mejoras de proceso que aumentaron la eficiencia de testing y la confianza en los releases.</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">Feb 2018<br/>Abr 2018</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">Software Engineer</h3>
              <p class="text-sm text-gray-400 mb-3">Neax</p>
              <ul class="text-sm text-gray-500 space-y-1.5">
                <li>Desarrollo de plataforma web de facturación electrónica con React y Node.js, en conformidad con regulaciones SUNAT de Perú.</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">Ene 2018<br/>Feb 2018</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">Software Engineer</h3>
              <p class="text-sm text-gray-400 mb-3">Atix</p>
              <ul class="text-sm text-gray-500 space-y-1.5">
                <li>Desarrollo de aplicación móvil de compras cross-platform con React Native y Node.js, integrando APIs RESTful.</li>
              </ul>
            </div>
          </div>

        </div>
      </section>

      <!-- EDUCACIÓN -->
      <section class="py-16 border-t border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-10">Educación & Certificaciones</h2>

        <div class="flex flex-col gap-8">

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">UNSA</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">Bachiller en Ciencias de la Computación</h3>
              <p class="text-sm text-gray-400">Universidad Nacional de San Agustín de Arequipa · Arequipa, Perú</p>
            </div>
          </div>

          <div class="flex gap-6">
            <span class="text-sm text-gray-400 w-28 shrink-0 pt-1">2018</span>
            <div>
              <h3 class="font-semibold text-base mb-0.5">ISTQB — Certified Tester Foundation Level</h3>
              <p class="text-sm text-gray-400">International Software Testing Qualifications Board</p>
            </div>
          </div>

        </div>
      </section>

      <!-- CTA -->
      <section class="py-16 border-t border-gray-100">
        <h2 class="text-2xl font-bold mb-3">¿Trabajamos juntos?</h2>
        <p class="text-gray-500 mb-6 text-sm">¿Necesitas un QA Engineer que asegure calidad desde el día uno? Hablemos.</p>
        <div class="flex gap-3">
          <a href="mailto:eduardo.macetas@gmail.com"
            class="bg-gray-900 text-white text-sm px-5 py-2.5 rounded-lg hover:bg-gray-700 transition font-medium">
            Enviar mensaje
          </a>
          <a href="https://www.linkedin.com/in/jorge-macetas" target="_blank"
            class="border border-gray-200 text-sm px-5 py-2.5 rounded-lg hover:bg-gray-50 transition font-medium text-gray-700">
            Conectar en LinkedIn
          </a>
        </div>
      </section>

    </main>

    <!-- FOOTER -->
    <footer class="max-w-4xl mx-auto px-6 py-8 border-t border-gray-100">
      <div class="flex justify-between items-center text-xs text-gray-400">
        <span>© 2026 Jorge Macetas</span>
        <div class="flex gap-4">
          <a href="https://github.com/eduardomacetas" target="_blank" class="hover:text-gray-700 transition">GitHub</a>
          <a href="https://www.linkedin.com/in/jorge-macetas" target="_blank" class="hover:text-gray-700 transition">LinkedIn</a>
          <a href="mailto:eduardo.macetas@gmail.com" class="hover:text-gray-700 transition">Email</a>
        </div>
      </div>
    </footer>

  </body>
</html>