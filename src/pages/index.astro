---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import AITools from "../components/AITools.astro";
import Skills from "../components/Skills.astro";
import Timeline from "../components/Timeline.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Education from "../components/Education.astro";
import Grid from "../components/Grid.astro";
import CallToAction from "../components/CallToAction.astro";

const projects = (await getCollection("projects")).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout>
	<!-- ── Hero ── -->
	<Hero />

	<!-- ── Stats ── -->
	<div class="stats-bar wrapper">
		<div class="stat">
			<span class="stat-n">7+</span>
			<span class="stat-l">Years experience</span>
		</div>
		<!-- <div class="stat-sep"></div>
		<div class="stat">
			<span class="stat-n">4</span>
			<span class="stat-l">Published apps</span>
		</div>
		<div class="stat-sep"></div>
		<div class="stat">
			<span class="stat-n">AI</span>
			<span class="stat-l">Native workflow</span>
		</div> -->
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Skills ── -->
	<div class="wrapper">
		<Skills />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── AI Tools ── -->
	<div class="wrapper">
		<AITools />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Experience ── -->
	<div class="wrapper">
		<Timeline />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Education ── -->
	<div class="wrapper">
		<Education />
	</div>
	
	<!-- <div class="divider wrapper"></div> -->

	<!-- ── Featured Projects ── -->
	<!-- <section class="projects wrapper">
		<div class="section-head">
			<h2 class="section-title">Projects</h2>
			<CallToAction href="/work/">
				All work <Icon icon="arrow-right" size="1em" />
			</CallToAction>
		</div>
		<Grid variant="small">
			{
				projects.map((p) => (
					<li>
						<PortfolioPreview project={p} />
					</li>
				))
			}
		</Grid>
	</section> -->

	<!-- ── Contact ── -->
	<!-- <div class="wrapper">
		<ContactCTA />
	</div> -->
</BaseLayout>

<style>
	/* ── Stats bar ── */
	.stats-bar {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding-block: 1.5rem;
		flex-wrap: wrap;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.stat-n {
		font-size: var(--text-xl);
		font-weight: 800;
		color: var(--gray-0);
		letter-spacing: -0.03em;
		line-height: 1;
	}

	.stat-l {
		font-size: var(--text-sm);
		color: var(--gray-500);
	}

	.stat-sep {
		width: 1px;
		height: 2.5rem;
		background: var(--gray-800);
		flex-shrink: 0;
	}

	/* ── Dividers ── */
	.divider {
		height: 1px;
		background: var(--gray-800);
		margin-block: 0;
	}

	/* ── Projects section ── */
	.projects {
		padding: 4rem 0;
	}

	.section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: var(--text-2xl);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--gray-0);
	}

</style>
